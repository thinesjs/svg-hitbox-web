{
  "name": "svg-hitbox-web",
  "private": true,
  "version": "1.6.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:ci": "vite build",
    "lint": "pnpm lint:rules && pnpm lint:code-format && pnpm lint:type-check",
    "lint:code-format": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "lint:fix": "pnpm lint:rules --fix && pnpm lint:code-format --write && pnpm lint:type-check",
    "lint:rules": "eslint . --cache",
    "lint:type-check": "tsc",
    "preview": "vite preview",
    "release:prod": "commit-and-tag-version --tag-prefix=v",
    "release:dry": "commit-and-tag-version --dry-run",
    "nuke": "rm -rf ./node_modules && rm -rf ./dist"
  },
  "dependencies": {
    "@fontsource-variable/figtree": "^5.2.10",
    "@remixicon/react": "^4.9.0",
    "@tailwindcss/vite": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shadcn": "^4.0.6",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0"
  },
  "packageManager": "pnpm@10.28.1",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "commit-and-tag-version": "^12.6.1",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.8.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^5.4.0"
  }
}
